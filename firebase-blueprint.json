{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A household product being tracked",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "currentQuantity": { "type": "number", "description": "Current amount in stock" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., liters, kg, pieces)" },
        "category": { "type": "string", "description": "Category of the product (e.g., Badeværelse, Køkken)" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this product" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "currentQuantity", "unit", "ownerId"]
    },
    "InventoryCheck": {
      "title": "InventoryCheck",
      "description": "A snapshot of product quantity at a point in time",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the product" },
        "quantity": { "type": "number", "description": "Quantity at this time" },
        "timestamp": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string", "description": "UID of the user who recorded this" }
      },
      "required": ["productId", "quantity", "timestamp", "ownerId"]
    },
    "Room": {
      "title": "Room",
      "description": "A room in the house for cleaning tracking",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the room" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "CleaningTask": {
      "title": "CleaningTask",
      "description": "A recurring cleaning task within a room",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "description": { "type": "string" },
        "intervalDays": { "type": "number" },
        "lastCompletedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "description", "intervalDays", "lastCompletedAt", "ownerId"]
    },
    "ShoppingListItem": {
      "title": "ShoppingListItem",
      "description": "An item on the shopping list",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "store": { "type": "string", "description": "The store to buy from (e.g., Netto, Rema 1000)" },
        "category": { "type": "string", "description": "Supermarket section (e.g., Grønt, Frost)" },
        "price": { "type": "number" },
        "isOffer": { "type": "boolean" },
        "isCompleted": { "type": "boolean" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "isCompleted"]
    },
    "MasterShoppingItem": {
      "title": "MasterShoppingItem",
      "description": "A recurring item that is always on the master list",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "store": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "ShoppingStat": {
      "title": "ShoppingStat",
      "description": "A record of a completed shopping item for statistics",
      "type": "object",
      "properties": {
        "itemName": { "type": "string" },
        "store": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["itemName", "store", "timestamp", "ownerId"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of household products"
    },
    "/inventoryChecks/{checkId}": {
      "schema": "InventoryCheck",
      "description": "History of inventory snapshots"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Rooms in the house"
    },
    "/cleaningTasks/{taskId}": {
      "schema": "CleaningTask",
      "description": "Cleaning tasks for rooms"
    },
    "/shoppingList/{itemId}": {
      "schema": "ShoppingListItem",
      "description": "Items on the shopping list"
    },
    "/masterShoppingList/{itemId}": {
      "schema": "MasterShoppingItem",
      "description": "Master list of recurring items"
    },
    "/shoppingStats/{statId}": {
      "schema": "ShoppingStat",
      "description": "Historical data for shopping analytics"
    }
  }
}
