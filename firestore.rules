rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - currentQuantity: number (required, >= 0)
    //   - unit: string (required, 1-20 chars)
    //   - ownerId: string (required, matches auth.uid)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: inventoryChecks
    // Fields:
    //   - productId: string (required)
    //   - quantity: number (required, >= 0)
    //   - timestamp: timestamp (required)
    //   - ownerId: string (required, matches auth.uid)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nd120391@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.currentQuantity is number && data.currentQuantity >= 0 &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() <= 20 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             data.ownerId == request.auth.uid;
    }

    function isValidInventoryCheck(data) {
      return data.productId is string &&
             data.quantity is number && data.quantity >= 0 &&
             data.ownerId == request.auth.uid;
    }

    function isValidRoom(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidCleaningTask(data) {
      return data.roomId is string &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 200 &&
             data.intervalDays is number && data.intervalDays > 0 &&
             data.lastCompletedAt is timestamp &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidShoppingListItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.store == null || (data.store is string && data.store.size() <= 50)) &&
             (data.category == null || (data.category is string && data.category.size() <= 50)) &&
             (data.price == null || data.price is number) &&
             (data.isOffer == null || data.isOffer is bool) &&
             data.isCompleted is bool &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidMasterShoppingItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.store == null || (data.store is string && data.store.size() <= 50)) &&
             (data.category == null || (data.category is string && data.category.size() <= 50)) &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidShoppingStat(data) {
      return data.itemName is string && data.itemName.size() > 0 &&
             data.store is string &&
             (data.category == null || data.category is string) &&
             (data.price == null || data.price is number) &&
             data.timestamp is timestamp &&
             data.ownerId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidProduct(request.resource.data) && 
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /inventoryChecks/{checkId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidInventoryCheck(request.resource.data);
      allow update: if false; 
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidRoom(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /cleaningTasks/{taskId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidCleaningTask(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidCleaningTask(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /shoppingList/{itemId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidShoppingListItem(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidShoppingListItem(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /masterShoppingList/{itemId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidMasterShoppingItem(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidMasterShoppingItem(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /shoppingStats/{statId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidShoppingStat(request.resource.data);
      allow update: if false;
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
